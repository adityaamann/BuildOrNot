{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install && npm --prefix Desktop/Build-or-Not/server install && npm --prefix Desktop/Build-or-Not/client install",
  "buildCommand": "npm --prefix Desktop/Build-or-Not/client run build",
  "outputDirectory": "Desktop/Build-or-Not/client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
